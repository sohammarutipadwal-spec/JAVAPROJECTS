import java.util.Scanner;
class Addition
{
  public static void main(String[] args)
  {
    Scanner sc = new Scanner(System.in);
    int num1,num2,sum;
     System.out.println("Enter 1st num:");
     num1=sc.nextInt();
      
     System.out.println("Enter 2nd num:");
     num2=sc.nextInt();
     
     sum = num1+num2;
     System.out.println("Sum " +sum);
  } 

}
